# Copy to .env at repo root for docker-compose, or to apps/<service>/.env for local runs.

# --- Postgres ---
POSTGRES_USER=deximon
POSTGRES_PASSWORD=deximon
POSTGRES_DB=deximon
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full URL used by apps/api (SQLAlchemy)
DATABASE_URL=postgresql+psycopg://deximon:deximon@postgres:5432/deximon

# --- Redis (chat fanout, future) ---
REDIS_URL=redis://redis:6379/0

# --- apps/api ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# Google OAuth (filled in Week 2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- apps/scanner ---
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=deximon-uploads-dev

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SCANNER_URL=http://localhost:8001
