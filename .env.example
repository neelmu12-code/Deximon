# Copy to .env at repo root for docker-compose, or to apps/<service>/.env for local runs.

# --- Postgres ---
POSTGRES_USER=deximon
POSTGRES_PASSWORD=deximon
POSTGRES_DB=deximon
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full URL used by apps/api (SQLAlchemy)
DATABASE_URL=postgresql+psycopg://deximon:deximon@postgres:5432/deximon

# --- Redis (chat fanout, future) ---
REDIS_URL=redis://redis:6379/0

# --- apps/api ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-before-running
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_SECURE=false
# Optional separate key for temporary OAuth state session cookies
SESSION_SECRET_KEY=

# Google OAuth - leave blank to disable the Google sign-in endpoints
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/auth/success
FRONTEND_AUTH_ERROR_URL=http://localhost:3000/login?error=oauth_failed

# --- apps/scanner ---
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8001
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=deximon-uploads-dev

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SCANNER_URL=http://localhost:8001
